# Gmail OAuth2 — required for sending emails
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Optional — Hunter.io free tier (25 lookups/month)
HUNTER_API_KEY=

# Database — defaults to local SQLite
DATABASE_URL=sqlite:///./jobscout.db

# Frontend origin — used for CORS
FRONTEND_URL=http://localhost:3000
