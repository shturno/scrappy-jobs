# Gmail OAuth2 — required for sending emails
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Optional — Hunter.io free tier (25 lookups/month)
HUNTER_API_KEY=

# Database — defaults to local SQLite
DATABASE_URL=sqlite:///./jobscout.db

# Frontend origin — used for CORS
FRONTEND_URL=http://localhost:3000

# Pipeline config — comma-separated
SEARCH_KEYWORDS=desenvolvedor backend,desenvolvedor frontend, react developer,fullstack
SEARCH_CITIES=São Paulo,Curitiba,Remoto

# Sender identity — used in email templates
SENDER_NAME=
SENDER_EMAIL=
SENDER_WHATSAPP=
SENDER_LINKEDIN=
SENDER_GITHUB=
SENDER_PORTFOLIO=
